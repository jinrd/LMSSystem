// Prisma Client 설정
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL DB 연결 설정
datasource db {
  provider = "postgresql"
}

// User 모델
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role  @default(STUDENT)
  termsAgreed Boolean
  createdAt DateTime @default(now())

  // 강좌, 강의를 위해 추가
  teachingClasses     Class[]     // 강사일 경우 담당하는 반들
  enrollments         Enrollment[]    // 학생일 경우 수강하는 반들


  // 이메일 검색 속도 향상을 위한 인덱싱
  @@index([email])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// 과목 (Course) - 교육과정의 뼈대
model Course {
  id          String  @id @default(uuid())
  title       String    // 강의명
  description  String?    // 과목 설명

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 이 과목으로 열리는 실제 수업 반(1:N 관계)
  classes     Class[]
}

// 강좌 (Class) - 실제로 날짜와 시간이 정해진 수업
model Class {
  id    Int   @id @default(autoincrement())
  name  String  // "26년 5월 주말반"
  capacity    Int     // 수강 정원

  startDate   DateTime    // 개강일
  endDate     DateTime    // 종강일

  // 어떤 과목의 강좌인지
  courseId      String
  course        Course    @relation(fields: [courseId], references: [id])

  // 강좌를 담당하는 강사는 누구인지 (User 테이블과 연결)
  instructorId    Int
  instructor      User     @relation(fields: [instructorId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime  @updatedAt

  // 이 반의 세부 시간표, 수강생, 과제들
  schedules     ClassSchedule[]
  enrollments   Enrollment[]
  
}

// 주간 스케줄 규칙
model ClassSchedule {
  id    Int   @id @default(autoincrement())

  // 0: 일, 1: 월, 2: 화, 3: 수, 4: 목, 5: 금, 6: 토
  dayOfWeek     Int

  // 시간만 텍스트로 저장("14:00")
  startTime     String
  endTime       String

  // 어떤 반의 스케줄인지
  classId       Int
  class         Class @relation(fields: [classId], references: [id], onDelete: Cascade)
}

// 수강 등록 - 학생과 반의 연결 고리
model Enrollment {
  id      Int     @id @default(autoincrement())
  status    String    @default("ENROLLED")    // ENROLLED, COMPLETED, CANCELLED 등

  studentId     Int
  student       User    @relation(fields: [studentId], references: [id])

  classId       Int
  class         Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime  @updatedAt

  // 한 명의 학생이 동일한 강의를 중복으로 수강하지 못하도록
  @@unique([studentId, classId])
}

model Notice {
  id          Int   @id @default(autoincrement())
  title       String
  content     String
  authorId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
