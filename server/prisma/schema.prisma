// Prisma Client 설정
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL DB 연결 설정
datasource db {
  provider = "postgresql"
}

// User 모델
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role  @default(STUDENT)
  termsAgreed Boolean
  createdAt DateTime @default(now())

  // 이메일 검색 속도 향상을 위한 인덱싱
  @@index([email])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}


model Course {
  id          String  @id @default(uuid())
  title       String    // 강의명
  instructor  String    // 강사명
  capacity    Int       //수용 가능한 수강생 수

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 강사명 또는 강의명으로 검색할 가능성이 높으므로 인덱싱
  @@index([title])
  @@index([instructor])
}

model Notice {
  id          Int   @id @default(autoincrement())
  title       String
  content     String
  authorId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
