// Prisma Client 설정
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL DB 연결 설정
datasource db {
  provider = "postgresql"
}

// User 모델
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role  @default(STUDENT)
  termsAgreed Boolean
  createdAt DateTime @default(now())

  // 강좌, 강의를 위해 추가
  teachingClasses     Class[]         // 강사일 경우 담당하는 반들
  enrollments         Enrollment[]    // 학생일 경우 수강하는 반들

  submissions         Submission[]    // 학생일 경우 제출한 과제들

  // 비밀번호 횟수 제한
  failedLoginAttempts     Int     @default(0)
  lockedUntil             DateTime?

  // 휴학/재학 상태 관리 필드
  status              String      @default("ACTIVE")

  resetPasswordToken    String?       // 비밀번호 재설정용 고유 토큰값(예 : UUID 또는 랜덤 문자열)
  resetPasswordExpires  DateTime?     // 비밀번호 재설정용 토큰 만료 시간(보통 생성 후 1시간)

  // 질문 관계용
  inquiries         Inquiry[]     @relation("StudentInquiries")
  answeredInquiries Inquiry[]     @relation("AnsweredInquiries")

  // 이메일 검색 속도 향상을 위한 인덱싱
  @@index([email])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// 과목 (Course) - 교육과정의 뼈대
model Course {
  id          String  @id @default(uuid())
  title       String    // 강의명
  description  String?    // 과목 설명

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 이 과목으로 열리는 실제 수업 반(1:N 관계)
  classes     Class[]
}

// 강좌 (Class) - 실제로 날짜와 시간이 정해진 수업
model Class {
  id    Int   @id @default(autoincrement())
  name  String  // "26년 5월 주말반"
  capacity    Int     // 수강 정원

  startDate   DateTime    // 개강일
  endDate     DateTime    // 종강일

  // 어떤 과목의 강좌인지
  courseId      String
  course        Course    @relation(fields: [courseId], references: [id])

  // 강좌를 담당하는 강사는 누구인지 (User 테이블과 연결)
  instructorId    Int
  instructor      User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime  @updatedAt

  // 이 반의 세부 시간표, 수강생, 과제들
  schedules     ClassSchedule[]
  enrollments   Enrollment[]
  assignments   Assignment[]
  
}

// 주간 스케줄 규칙
model ClassSchedule {
  id    Int   @id @default(autoincrement())

  // 0: 일, 1: 월, 2: 화, 3: 수, 4: 목, 5: 금, 6: 토
  dayOfWeek     Int

  // 시간만 텍스트로 저장("14:00")
  startTime     String
  endTime       String

  // 어떤 반의 스케줄인지
  classId       Int
  class         Class @relation(fields: [classId], references: [id], onDelete: Cascade)
}

// 수강 등록 - 학생과 반의 연결 고리
model Enrollment {
  id      Int     @id @default(autoincrement())
  status    String    @default("ENROLLED")    // ENROLLED, COMPLETED, CANCELLED 등

  studentId     Int
  student       User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId       Int
  class         Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime  @updatedAt

  // 한 명의 학생이 동일한 강의를 중복으로 수강하지 못하도록
  @@unique([studentId, classId])
}

model Notice {
  id          Int   @id @default(autoincrement())
  title       String
  content     String
  authorId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 선생님이 출제한 과제
model Assignment {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime

  classId     Int
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  // 이 과제에 제출된 결과물들 (양방향 관계)
  submissions Submission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 학생들이 제출한 과제 결과물
model Submission {
  id           Int        @id @default(autoincrement())
  content      String?    // 내용만 있거나
  fileUrl      String?    // 첨부파일만 있을 수도 있음
  
  assignmentId Int
  assignment   Assignment @relation(fields:[assignmentId], references:[id], onDelete: Cascade)

  studentId    Int
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  status       String     @default("SUBMITTED")   // 제출 상태
  score        Int?       // 채점 점수 (선택)
  feedback     String?    // 선생님 피드백 (선택)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  // 한 학생은 하나의 과제에 대해 하나의 제출물만 가짐 (중복 제출 방지)
  @@unique([assignmentId, studentId])
}

// 에러 및 시스템 히스토리 로그 모델
model SystemLog {
  id        Int       @id @default(autoincrement())
  level     String    // "ERROR", "INFO", "WARN"
  message   String    // 에러 메세지 또는 히스토리 내용
  stack     String?   // 에러 스택 트레이스 (선택)
  userId    Int?      // 관련된 사용자 ID(있을 경우)
  route     String?   // 에러가 발생한 API 라우트
  createdAt DateTime @default(now())
}


// 1:1 문의 (Q&A) 모델
model Inquiry {
  id      Int       @id @default(autoincrement())
  title   String
  content String
  status  String    @default("PENDING")   // "PENDING"(답변대기), "ANSWERED"(답변완료)

  // 질문한 학생
  studentId   Int
  student     User  @relation("StudentInquiries", fields: [studentId], references: [id], onDelete: Cascade)

  // 답변 내용 및 답변한 강사/관리자
  answer      String?
  answeredById  Int?
  answeredBy   User?    @relation("AnsweredInquiries", fields: [answeredById], references: [id], onDelete: SetNull)
  answeredAt    DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}