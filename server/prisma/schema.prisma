// Prisma Client 설정
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL DB 연결 설정
datasource db {
  provider = "postgresql"
}

// User 모델
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}
